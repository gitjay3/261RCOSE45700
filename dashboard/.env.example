# Tracker dashboard 환경 변수
# - VITE_ prefix만 클라이언트 번들에 노출됨 (Vite 표준)
# - 미설정 시 axios baseURL 기본값 '/api' 사용 (production 빌드에선 nginx /api proxy로 라우팅)
# - 로컬 dev에서는 Vite dev server(5173) → Spring Boot(8080) 직접 호출. API controller가
#   @RequestMapping("/api") 매핑이므로 base URL에 `/api` 경로까지 포함 필수.

VITE_API_BASE_URL=http://localhost:8080/api
