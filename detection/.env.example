# detection-specific tunables only.
# 공통 OPENAI_API_KEY / LLM_MODEL / LLM_DAILY_COST_CAP_USD / LLM_SEND_IMAGES / LLM_SPLIT_TEXT_IMAGE /
# LLM_WORKER_COUNT / LLM_TIMEOUT_SEC 는 monorepo SSOT인 infra/.env.example 참조.

# ===================================================
# Story 3-7 — 멀티 에이전트 오케스트레이터 + 트리아지 + LinkTracer (2026-06-11 재정의)
# ===================================================

# 파이프라인 모드: single(기존 단일 호출) | agentic(S0→S1→fast path|escalate→degrade).
# 기본 single — 데모 당일 A/B(Story 3-9) 결과로 agentic 전환 결정.
DETECTION_MODE=single

# S1 트리아지 모델 (저비용 1차 분류). 기본 gpt-4o-mini.
TRIAGE_MODEL=gpt-4o-mini

# FAST PATH 임계 — type=기타 ∧ confidence≥값 ∧ 의심 링크 없음이면 트리아지 결과를 최종 verdict로.
# Story 3-9에서 escalation율 측정 후 튜닝.
FAST_PATH_CONFIDENCE=0.80

# S2b LinkTracer — 1-hop 링크 추적 (FR12-B)
# LINK_TRACE_PROXY 설정 시 모든 fetch가 egress 프록시 경유 (대학/가정 IP 노출 회피).
# LINK_TRACE_PROXY=http://proxy.example:8080
LINK_TRACE_TIMEOUT_SEC=5
# 응답 바이트 상한 (기본 512KB).
LINK_TRACE_MAX_BYTES=524288

# ===================================================
# 비용 단가표 — 멀티 프로바이더 (cost_cap.py)
# ===================================================
# 단가 미등록 모델에 적용할 fallback 모델 (기본 gpt-4o). 미등록 시 경고 1회 + 이 모델 단가로 추정.
LLM_PRICING_FALLBACK_MODEL=gpt-4o
# 코드 수정 없이 단가 추가·갱신: 파일 경로 또는 인라인 JSON. {"model": {"input": x, "output": y}} (USD/1M).
# 예) LLM_PRICING_OVERRIDES_JSON={"gpt-5.5": {"input": 1.25, "output": 10.0}}
# LLM_PRICING_OVERRIDES_JSON=

# ===================================================
# Story 3-3 — OpenAI 멀티모달 LLM 분류 + Tier 라우팅 (2026-05-27 PIVOT 신규)
# ===================================================

# Rate limit 토큰 버킷 (Redis DB2, llm:rate_limit) — OpenAI tier에 맞춰 조정
LLM_RATE_LIMIT_CAPACITY=60
LLM_RATE_LIMIT_REFILL_PER_SEC=1
LLM_RATE_LIMIT_MAX_WAIT_SEC=120

# Tier별 차등 retry — Story 3-3 AC
RETRY_T1_MAX_ATTEMPTS=3
RETRY_T2_MAX_ATTEMPTS=2
RETRY_T3_MAX_ATTEMPTS=1
RETRY_T4_MAX_ATTEMPTS=0
RETRY_BACKOFF_BASE_SEC=1

# ===================================================
# Transitional (Story 3-2 cleanup 후 잔존, Story 3-3에서 제거 예정)
# ===================================================
# 아래 VARCO_* 변수는 Story 3-3에서 OpenAI llm_client.py + tier_config.py로
# 전면 대체되며, 코드 상수도 LLM_* 네이밍으로 rename된다. 현재는 transitional state.

# retry_handler.py — Story 3-3에서 Tier별 차등 retry로 교체 (위 RETRY_T*_MAX_ATTEMPTS)
RETRY_MAX_ATTEMPTS=3
