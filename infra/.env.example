# ===================================================
# Tracker Local Development Environment Variables
# Usage: cp infra/.env.example infra/.env
#        (or copy to project root as .env)
# NEVER commit .env files to version control
# ===================================================

# -------- VARCO API --------
VARCO_API_KEY=your-varco-api-key-here

# -------- AWS --------
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=your-s3-bucket-name-here
# EC2 IAM Role 기반 자격증명 사용. Access Key 하드코딩 금지 (NFR6)
# AWS_ACCESS_KEY_ID=do-not-set-use-iam-role
# AWS_SECRET_ACCESS_KEY=do-not-set-use-iam-role

# -------- Crawling Schedule --------
# 크롤링 주기 (분 단위). 환경변수 변경만으로 적용, 재배포 불필요 (NFR17)
CRAWL_INTERVAL_MINUTES=60

# -------- Redis --------
REDIS_HOST=localhost
REDIS_PORT=6379
# 호스트 포트 충돌 회피 (다른 Redis 컨테이너 사용 중일 때 오버라이드)
REDIS_HOST_PORT=6379
# DB 역할 분리 — 단일 인스턴스에서 논리 분리 (OOM 시 4기능 동시 장애 방지)
# posts:queue / posts:processing / posts:dlq
REDIS_MQ_DB=0
# posts:dedup (SHA-256 해시 SET)
REDIS_DEDUP_DB=1
# varco:rate_limit (토큰 버킷)
REDIS_RATELIMIT_DB=2
# cache:detections (API 응답 캐시)
REDIS_CACHE_DB=3

# -------- PostgreSQL --------
DB_HOST=localhost
DB_PORT=5432
# 호스트 포트 충돌 회피 (다른 Postgres 사용 중일 때 오버라이드)
DB_HOST_PORT=5432
DB_NAME=tracker
DB_USER=tracker_user
DB_PASSWORD=your-db-password-here

# -------- Structured Logging --------
# 허용값: crawler | detection | api  (하드코딩 금지 — NFR5)
SERVICE_NAME=crawler
LOG_LEVEL=DEBUG
