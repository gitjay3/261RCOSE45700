# ===================================================
# Tracker Local Development Environment Variables
# Usage: cp infra/.env.example infra/.env
#        (or copy to project root as .env)
# NEVER commit .env files to version control
#
# 시크릿(API key, password)만 placeholder, 비-시크릿은 동작 가능한 default.
# `cp .env.example .env`로 바로 로컬 docker-compose 가동되도록 유지.
# ===================================================

# -------- LLM API Key (2026-05-27 PIVOT — OpenAI 멀티모달) --------
# OpenAI 멀티모달 LLM(GPT-4o/4.1) — Story 3-3 단일 호출로 분류·reason_ko·translated_text_ko·Tier 라우팅 동시 산출
# 본 키는 placeholder. 실제 키는 본인 손으로 .env에 sk-... 형식으로 추가 (gitignore됨).
# 발급: platform.openai.com → API keys
# 절대 코드 저장소에 커밋 금지 (NFR5)
OPENAI_API_KEY=sk-REPLACE-WITH-YOUR-OWN-KEY
# 모델 선택. 멀티모달 지원 모델만 사용 (gpt-4o, gpt-4o-mini, gpt-4.1 등). SPIKE 3.0 단가 측정 후 확정.
LLM_MODEL=gpt-4o
# 일일 비용 cap (USD). 누적 비용 도달 시 큐 대기(Hold). SPIKE 단가 측정 후 조정.
LLM_DAILY_COST_CAP_USD=5
# 이미지 OpenAI 전송 토글 — 법무 검토 전 false로 유지(텍스트-only fallback). 검토 후 true.
LLM_SEND_IMAGES=false
# 텍스트/이미지 호출 분리 — 기본 false(단일 호출). 비용·정확도 측정 후 true 검토.
LLM_SPLIT_TEXT_IMAGE=false
# 동시 worker 수 — 시작값 1, OpenAI rate limit과 비용 cap 운영 데이터로 조정.
LLM_WORKER_COUNT=1
# 요청 타임아웃(초)
LLM_TIMEOUT_SEC=30
# model_version 포맷용 (`openai:{model}:{date}`). 미설정 시 현재 UTC 날짜 사용.
LLM_MODEL_RELEASE_DATE=2024-08-06
# LLM 토큰 버킷 — Redis DB2 `llm:rate_limit:classify`
LLM_RATE_LIMIT_CAPACITY=60
LLM_RATE_LIMIT_REFILL_PER_SEC=1
LLM_RATE_LIMIT_MAX_WAIT_SEC=120

# -------- Tier 디스플레이 threshold (대시보드 필터 — RDS 저장 분기에는 미사용) --------
TIER_THRESHOLD_T1=0.65
TIER_THRESHOLD_T2=0.75
TIER_THRESHOLD_T3=0.85
TIER_THRESHOLD_T4=0.90

# -------- T1 Critical 알림 (Story 3-6) --------
# 운영팀 협의 후 채널 확정 (slack | email | webhook | disabled). 기본 disabled.
T1_NOTIFICATION_CHANNEL=disabled
# 채널별 endpoint (선택값에 맞춰 한 개만 채움)
# T1_SLACK_WEBHOOK_URL=
# T1_EMAIL_TO=
# T1_WEBHOOK_URL=

# -------- AWS --------
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name-here
# crawler `PostStorage` 의 S3 업로드 분기 플래그. true 시 S3_BUCKET_NAME 필수.
ENABLE_S3_UPLOAD=false
# EC2 IAM Role 기반 자격증명 사용. Access Key 하드코딩 금지 (NFR6)
# AWS_ACCESS_KEY_ID=do-not-set-use-iam-role
# AWS_SECRET_ACCESS_KEY=do-not-set-use-iam-role

# -------- Crawling Schedule --------
# 크롤링 주기 (분 단위). 환경변수 변경만으로 적용, 재배포 불필요 (NFR17)
CRAWL_INTERVAL_MINUTES=60
# 운영 기본 profile — EC2 1대 + RDS 1대 기준.
# listing 후보 폭은 넓히되, detail fetch는 priority budget과 source별 concurrency로 제어한다.
MAX_POSTS_PER_BOARD=30
CRAWL_PRIORITY_BUDGET_ENABLED=true
CRAWL_P3_DEFAULT_CAP_PER_BOARD=1
CRAWL_P3_MIXED_CAP_PER_BOARD=5
CRAWL_P3_52POJIE_CAP_PER_BOARD=1
CRAWL_DETAIL_FETCH_CONCURRENCY=3
CRAWL_DETAIL_SOURCE_CONCURRENCY=dcard=1,dcard_online=1,52pojie=1
CRAWL_DETAIL_FETCH_STAGGER_SECONDS=0.25
# Dcard/52pojie anti-bot 실패는 운영에서 기록 후 통과. retry/cooldown 기본 off.
CRAWL_DETAIL_CLOUDFLARE_BACKOFF_RETRIES=0
CRAWL_DETAIL_CLOUDFLARE_BACKOFF_SECONDS=0
CRAWL_DETAIL_SOURCE_COOLDOWN_SECONDS=0
CRAWL_DETAIL_CHALLENGE_COOLDOWN_SECONDS=0
INTER_SITE_DELAY_SECONDS=15
INTER_BOARD_DELAY_SECONDS=3

# -------- Redis --------
# Python 서비스(crawler, detection)는 REDIS_URL 단일 변수를 읽음.
# Spring Boot API는 host/port 별도 변수를 읽음.
# 로컬 dev default — 운영 환경에서는 docker network hostname `redis`로 override 필요.
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# CVE-2025-49844 (CVSS 10.0): Redis requirepass 없이 Lua NOAUTH RCE 가능.
# 운영 compose.prod.yml에서 반드시 requirepass 설정하고 동일 값을 입력할 것.
# 로컬 docker-compose는 비워도 무방 (외부 포트 미노출).
REDIS_PASSWORD=
# 호스트 포트 충돌 회피 (다른 Redis 컨테이너 사용 중일 때 오버라이드)
REDIS_HOST_PORT=6379
# DB 역할 분리 — 단일 인스턴스에서 논리 분리 (OOM 시 4기능 동시 장애 방지)
# posts:queue / posts:processing / posts:dlq
REDIS_MQ_DB=0
# detection BRPOPLPUSH 대기보다 길게 설정해야 Redis read timeout으로 consumer가 종료되지 않음.
# 미설정 시 BRPOPLPUSH_TIMEOUT + 10초.
REDIS_MQ_SOCKET_TIMEOUT_SEC=40
# posts:dedup (SHA-256 해시 SET)
REDIS_DEDUP_DB=1
# llm:rate_limit (토큰 버킷) — 2026-05-27 PIVOT, varco: prefix 폐기
REDIS_RATELIMIT_DB=2
# cache:detections (API 응답 캐시)
REDIS_CACHE_DB=3

# -------- PostgreSQL --------
DB_HOST=localhost
DB_PORT=5432
# 호스트 포트 충돌 회피 (다른 Postgres 사용 중일 때 오버라이드)
DB_HOST_PORT=5432
DB_NAME=tracker
DB_USER=tracker_user
DB_PASSWORD=your-db-password-here
# JDBC SSL 모드. 로컬 docker-compose는 SSL 미설정 → disable.
# 운영 RDS는 parameter group `rds.force_ssl=1` 적용 시 require 필수 (운영 .env에서 override).
DB_SSL_MODE=disable

# -------- Notifications --------
# Webhook URL 암호화 키. 운영에서는 반드시 32자 이상 난수로 설정.
NOTIFICATION_ENCRYPTION_KEY=dev-notification-key-change-me-32

# -------- Structured Logging --------
# 허용값: crawler | detection | api  (하드코딩 금지 — NFR5)
SERVICE_NAME=crawler
LOG_LEVEL=DEBUG

# -------- Swagger (Spring API) --------
# 로컬 개발에서만 활성화. 운영 .env에는 포함하지 말 것 (API 스펙 외부 노출 방지).
SWAGGER_ENABLED=true
